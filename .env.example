# Claude Code Dashboard Environment Variables

# Session secret for cookie signing (generate a random string)
SESSION_SECRET=your-secret-key-here

# Optional: Override the Claude projects directory (defaults to ~/.claude/projects)
# CLAUDE_PROJECTS_DIR=/path/to/.claude/projects

# Optional: Override the Claude config file (defaults to ~/.claude/config.json)
# CLAUDE_CONFIG_FILE=/path/to/.claude/config.json
